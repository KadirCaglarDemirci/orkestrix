{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "paths": {
      "@flowmatic/types": ["../../packages/types/src"],
      "@flowmatic/integrations": ["../../packages/integrations/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
